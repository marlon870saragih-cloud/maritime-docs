# ============================================================
#  MARITIME DOCS — contoh environment variables
#  Salin file ini jadi ".env" lalu isi nilainya.
# ============================================================

# --- Database (PostgreSQL) ---
# LOKAL: isi keduanya dengan koneksi PostgreSQL di komputer Anda (sama).
# CLOUD (Neon / Vercel Postgres):
#   DATABASE_URL = koneksi "Pooled" (hostnya ada "-pooler")
#   DIRECT_URL   = koneksi "Direct / non-pooling"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maritime_docs?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/maritime_docs?schema=public"

# --- NextAuth ---
# NEXTAUTH_URL = alamat aplikasi.
#   Lokal:  http://localhost:3000
#   Cloud:  https://nama-app-anda.vercel.app  (alamat dari Vercel)
# NEXTAUTH_SECRET = string acak panjang. Buat dengan:  openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-string"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Maritime Docs"
APP_TIMEZONE="Asia/Jakarta"
